{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "1. Avvia il cluster minikube",
            "type": "shell",
            "command": "minikube start --driver=docker --gpus all --memory 12288 --cpus 6",
            "presentation": {
                "reveal": "always",
                "panel": "new",
                "group": "minikube-testing"
            }
        },
        {
            "label": "2. Monta il Data Lake dei modelli nel cluster",
            "type": "shell",
            "command": "minikube mount \"/mnt/d/AI-Models:/data/hdd_models\"",
            "isBackground": true,
            "presentation": {
                "reveal": "always",
                "panel": "new",
                "group": "minikube-testing"
            }
        },
        {
            "label": "=== AVVIA Minikube ===",
            "dependsOn": [
                "1. Avvia il cluster minikube",
                "2. Monta il Data Lake dei modelli nel cluster"
            ],
            "dependsOrder": "parallel",
            "problemMatcher": []
        },
        {
            "label": "[TEST Embedding] Apri tunnel di port-forwarding per testare l'embedding model",
            "type": "shell",
            "command": "kubectl port-forward svc/embedding-service 8000:80",
            "isBackground": true,
            "presentation": {
                "reveal": "always",
                "panel": "new",
                "group": "minikube-testing"
            }
        },
        {
            "label": "[TEST LLM] Apri tunnel di port-forwarding per testare l'LLM",
            "type": "shell",
            "command": "kubectl port-forward svc/llm-service 8001:80",
            "isBackground": true,
            "presentation": {
                "reveal": "always",
                "panel": "new",
                "group": "minikube-testing"
            }
        },
        {
            "label": "[TEST KAFKA-CONNECT] Apri tunnel di port-forwarding per testare l'API di Kafka-Connect",
            "type": "shell",
            "command": "kubectl port-forward svc/kafka-connect-service 8083:8083",
            "isBackground": true,
            "presentation": {
                "reveal": "always",
                "panel": "new",
                "group": "minikube-testing"
            }
        },
        {
            "label": "[TEST DB] Apri tunnel di port-forwarding per avere accesso al DB da Neo4j Desktop",
            "type": "shell",
            "command": "kubectl port-forward svc/db-service 7474:7474 7687:7687 --address 0.0.0.0",
            "isBackground": true,
            "presentation": {
                "reveal": "always",
                "panel": "new",
                "group": "minikube-testing"
            }
        },
        {
            "label": "[MOUNT] Attiva mount per il data-exchange dell'audio del TTS",
            "type": "shell",
            "command": "minikube mount \"./data_exchange:/data/audio_files\"",
            "isBackground": true,
            "presentation": {
                "reveal": "always",
                "panel": "new",
                "group": "minikube-testing"
            }
        },
        {
            "label": "[MOUNT] Attiva mount per il logging",
            "type": "shell",
            "command": "minikube mount \"./logging:/logging\"",
            "isBackground": true,
            "presentation": {
                "reveal": "always",
                "panel": "new",
                "group": "minikube-testing"
            }
        }
    ]
}